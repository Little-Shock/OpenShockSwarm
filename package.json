{
  "name": "openshock",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:server": "bash -lc 'root=$(pwd); cd apps/server && OPENSHOCK_WORKSPACE_ROOT=\"${OPENSHOCK_WORKSPACE_ROOT:-$root}\" \"$root/scripts/go.sh\" run ./cmd/openshock-server'",
    "dev:daemon": "bash -lc 'root=$(pwd); cd apps/daemon && \"$root/scripts/go.sh\" run ./cmd/openshock-daemon --workspace-root \"${OPENSHOCK_WORKSPACE_ROOT:-$root}\"'",
    "dev:fresh:start": "node ./scripts/dev-fresh-stack.mjs start",
    "dev:fresh:stop": "node ./scripts/dev-fresh-stack.mjs stop",
    "dev:fresh:status": "node ./scripts/dev-fresh-stack.mjs status",
    "test:dev-fresh-stack:runtime": "node --test ./scripts/dev-fresh-stack-runtime.test.mjs",
    "build": "pnpm build:web",
    "build:web": "bash -lc 'cd apps/web && pnpm build'",
    "clean:web-e2e-dist": "node ./scripts/clean-next-e2e-dist.mjs",
    "check:live-truth-hygiene": "node ./scripts/check-live-truth-hygiene.mjs",
    "lint": "pnpm lint:web",
    "lint:web": "pnpm --dir apps/web lint",
    "test:web-contracts": "bash -lc 'cd apps/web && node --import tsx --test src/lib/*.test.ts'",
    "test:web-first-start-runtime-selection": "bash -lc 'cd apps/web && node --import tsx --test src/lib/onboarding-runtime-selection.test.ts'",
    "typecheck": "pnpm typecheck:web",
    "typecheck:web": "pnpm --dir apps/web typecheck",
    "verify": "pnpm verify:web && pnpm verify:go",
    "verify:web": "pnpm clean:web-e2e-dist && pnpm check:live-truth-hygiene && pnpm test:web-contracts && pnpm lint:web && pnpm typecheck:web && OPENSHOCK_NEXT_DIST_DIR=.next-verify-$$ node ./scripts/verify-web-build.mjs && pnpm clean:web-e2e-dist",
    "verify:go": "pnpm verify:server && pnpm verify:daemon",
    "verify:release": "bash ./scripts/release-gate.sh repo",
    "verify:release:full": "bash ./scripts/release-gate.sh all",
    "verify:release:rc": "bash ./scripts/release-gate.sh rc",
    "verify:release:browser": "bash ./scripts/release-gate.sh browser",
