    "test:headed-work-shell-smoke": "node ./scripts/headed-work-shell-smoke.mjs",
    "test:headed-mailbox-batch-actions": "node ./scripts/headed-mailbox-batch-actions.mjs",
    "test:headed-remote-pr-loop": "node ./scripts/headed-remote-pr-browser-loop.mjs",
    "test:headed-github-public-ingress": "node ./scripts/headed-github-public-ingress.mjs",
    "test:headed-pr-conversation-usage-observability": "node ./scripts/headed-pr-conversation-usage-observability.mjs",
