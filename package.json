    "verify:server:core": "bash -lc 'root=$(pwd); cd apps/server && OPENSHOCK_WORKSPACE_ROOT=\"${OPENSHOCK_WORKSPACE_ROOT:-$root}\" \"$root/scripts/go.sh\" test ./...'",
    "verify:server:integration": "bash -lc 'root=$(pwd); cd apps/server && OPENSHOCK_WORKSPACE_ROOT=\"${OPENSHOCK_WORKSPACE_ROOT:-$root}\" \"$root/scripts/go.sh\" test -tags=integration ./internal/integration -run TestPhaseZeroLoopThroughDaemon -count=1'",
    "verify:daemon": "bash -lc 'root=$(pwd); cd apps/daemon && \"$root/scripts/go.sh\" test ./...'",
    "ops:smoke": "bash ./scripts/ops-smoke.sh",
    "ops:smoke:strict": "OPENSHOCK_REQUIRE_GITHUB_READY=1 OPENSHOCK_REQUIRE_BRANCH_HEAD_ALIGNED=1 bash ./scripts/ops-smoke.sh",
