    "test:contract-website-four-agent-delivery": "bash -lc 'root=$(pwd); cd apps/server && GOCACHE=\"${GOCACHE:-/tmp/openshock-go-build-cache}\" GOMODCACHE=\"${GOMODCACHE:-/tmp/openshock-go-mod-cache}\" OPENSHOCK_WORKSPACE_ROOT=\"${OPENSHOCK_WORKSPACE_ROOT:-$root}\" \"$root/scripts/go.sh\" test ./internal/api -run TestWebsiteFourAgentDeliveryContractReplayWithoutListener -count=1'",
